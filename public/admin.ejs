<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Panel</title>
    <style>
        /* Basic reset */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        /* Body styling */
        body {
            font-family: Arial, sans-serif;
            background-color: #f4f7f6;
            color: #333;
            line-height: 1.6;
            padding: 20px;
        }

        h1 {
            color: #2c3e50;
            text-align: center;
            font-size: 3rem;
            margin-bottom: 40px;
        }

        h2 {
            color: #34495e;
            font-size: 2rem;
            margin-bottom: 20px;
            border-bottom: 2px solid #16a085;
            padding-bottom: 10px;
            margin-top: 30px;
        }

        /* List styling */
        ul {
            list-style-type: none;
            margin-top: 20px;
            padding: 0;
        }

        li {
            padding: 12px;
            margin-bottom: 10px;
            background-color: #ecf0f1;
            border-left: 5px solid #16a085;
            font-size: 1.1rem;
            color: #34495e;
            border-radius: 5px;
            transition: background-color 0.3s, border-color 0.3s;
        }

        li:hover {
            background-color: #dbe8e4;
            border-color: #1abc9c;
        }

        /* Admin panel container */
        .admin-container {
            width: 80%;
            margin: 0 auto;
            max-width: 1200px;
        }

        /* Responsive design */
        @media (max-width: 768px) {
            h1 {
                font-size: 2.5rem;
            }

            h2 {
                font-size: 1.8rem;
            }

            .admin-container {
                width: 100%;
                padding: 10px;
            }

            li {
                font-size: 1rem;
            }
        }
    </style>
</head>
<body>

    <div class="admin-container">
        <h1>Admin Panel</h1>

        <h2>Users</h2>
        <ul>
            <% users.forEach(user => { %>
                <li><%= user.name %> (<%= user.email %>)</li>
            <% }); %>
        </ul>

        <h2>Accounts</h2>
        <ul>
            <% accounts.forEach(account => { %>
                <li><%= account.userId.name %>: Balance: <%= account.balance %></li>
            <% }); %>
        </ul>
    </div>

</body>
</html>
