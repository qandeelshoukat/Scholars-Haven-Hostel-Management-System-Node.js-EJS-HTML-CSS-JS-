/* wrapper */
.image-wrapper {
width: 100vw; 
height: 75vh; 
overflow: hidden;
position: relative;
}

.image-wrapper img {
object-fit: fill;
width: 100%;
height: 100%;
position: absolute;
top: 0;
left: 0;
opacity: 0;
transition: opacity 0.5s ease-in-out;
}

.image-wrapper img.active {
opacity: 1;
}
.footer {
height:auto;
}

</style>
</head>
