<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>eFinConnect</title>
    <link rel="icon" href="icon.png">
    <style>
        /* General Styling */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: Arial, sans-serif;
            background-image: linear-gradient(rgba(4, 9, 30, 0.7), rgba(4, 9, 30, 0.7)), url("img2.jpg");
            background-position: center;
            background-size: cover;
            display: flex;
            background-repeat: no-repeat; /* Prevent image repetition */
            background-attachment: fixed;
        }

        .sidebar {
            width: 250px;
            height: 100vh;
            padding: 20px;
            box-shadow: 4px 0 8px rgba(0, 0, 0, 0.1);
            color: white;
        }

        .sidebar h1 {
            font-size: 1.5em;
            margin-bottom: 20px;
        }

        .sidebar nav {
            display: flex;
            flex-direction: column;
        }

        .sidebar nav a {
            color: white;
            text-decoration: none;
            padding: 10px 15px;
            border-radius: 5px;
            margin-bottom: 10px;
            transition: background-color 0.3s ease;
        }

        .sidebar nav a:hover {
            background-color: #1c6cd5;
        }

        main {
            flex-grow: 1;
            padding: 20px;
            display: flex;
            flex-wrap: wrap;
            gap: 20px;
            justify-content: center;
        }

        /* Account Summary */
        .account-summary {
            background-color: rgba(255, 255, 255, 0.9);
            padding: 20px;
            margin: 20px;
            border-radius: 10px;
            box-shadow: 0 6px 12px rgba(0, 0, 0, 0.2);
            flex: 1 1 45%;
            max-width: 600px;
        }

        .account-summary p {
            font-size: 24px;
            line-height: 1.6;
        }

        .account-summary strong {
            font-weight: bold;
        }

        /* Form Sections */
        .form-section {
            background-color: rgba(255, 255, 255, 0.9);
            padding: 20px;
            margin: 20px;
            border-radius: 10px;
            box-shadow: 0 6px 12px rgba(0, 0, 0, 0.2);
            flex: 1 1 45%;
            max-width: 600px;
        }

        .form-section h3 {
            margin-bottom: 15px;
            color: #333;
        }

        .form-section form {
            display: flex;
            flex-direction: column;
        }

        .form-section label {
            margin-bottom: 8px;
            font-weight: bold;
        }

        .form-section input {
            padding: 12px;
            margin-bottom: 15px;
            border-radius: 5px;
            border: 1px solid #ccc;
            font-size: 16px;
        }

        .form-section button {
            padding: 12px;
            background-color: #1a73e8;
            color: white;
            border: none;
            border-radius: 5px;
            font-size: 16px;
            cursor: pointer;
            transition: transform 0.2s, background-color 0.3s;
        }

        .form-section button:hover {
            background-color: #155bb5;
            transform: translateY(-3px);
        }

        /* Transaction History */
        .transactions {
            max-width: 800px;
            margin: 20px auto;
            background-color: rgba(255, 255, 255, 0.9);
            padding: 20px;
            border-radius: 10px;
            box-shadow: 0 6px 12px rgba(0, 0, 0, 0.2);
            flex: 1 1 100%;
        }

        .transactions h3 {
            margin-bottom: 15px;
            color: #333;
        }

        .transactions table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 20px;
        }

        .transactions table th,
        .transactions table td {
            padding: 12px;
            text-align: left;
            border: 1px solid #ddd;
        }

        .transactions table th {
            background-color: #f1f1f1;
            color: #333;
        }

        .transactions table tr:nth-child(even) {
            background-color: #f9f9f9;
        }

        .transactions table tr:hover {
            background-color: #e9e9e9;
        }
    </style>
</head>

<body>
    <div class="sidebar">
        <h1><%= name %>!</h1>
        <nav>
            <a href="">Dashboard</a>
            <a href="Settings.html">Settings</a>
            <a href="logout.html">Logout</a>
        </nav>
    </div>

    <main>
       <section class="account-summary">
            <h2>Account Information</h2>
            <div class="account-details">
                <p><strong>Account Number:</strong>
                    <%= accountNumber %>
                </p>
                <p><strong>Balance:</strong> $<%= balance %>
                </p>
            </div>
        </section>

        <!-- Deposit Form -->
        <section class="form-section">
            <h3>Deposit Funds</h3>
            <form action="/deposit" method="POST">
                <label for="amount">Amount (RS):</label>
                <input type="number" name="amount" id="amount" required>
                <label for="description">Description:</label>
                <input list="deposit-options" name="description" id="description" placeholder="Select or type...">
                <datalist id="deposit-options">
                    <option value="Salary">
                    <option value="Gift">
                    <option value="Investment">
                </datalist>
                <button type="submit">Deposit</button>
            </form>
        </section>

        <!-- Withdrawal Form -->
        <section class="form-section">
            <h3>Withdraw Funds</h3>
            <form action="/withdraw" method="POST">
                <label for="withdraw-amount">Amount ($):</label>
                <input type="number" name="amount" id="withdraw-amount" required>
                <label for="withdraw-description">Description:</label>
                <input list="withdraw-options" name="description" id="withdraw-description" placeholder="Select or type...">
                <datalist id="withdraw-options">
                    <option value="Groceries">
                    <option value="Bills">
                    <option value="Entertainment">
                </datalist>
                <button type="submit">Withdraw</button>
            </form>
        </section>

        <!-- Transfer Form -->
        <section class="form-section">
            <h3>Transfer Funds</h3>
            <form action="/transfer" method="POST">
                <label for="toAccountNumber">To Account Number:</label>
                <input type="text" name="toAccountNumber" id="toAccountNumber" required>
                <label for="transfer-amount">Amount ($):</label>
                <input type="number" name="amount" id="transfer-amount" required>
                <label for="transfer-description">Description:</label>
                <input list="transfer-options" name="description" id="transfer-description" placeholder="Select or type...">
                <datalist id="transfer-options">
                    <option value="Family Support">
                    <option value="Loan Repayment">
                    <option value="Savings">
                </datalist>
                <button type="submit">Transfer</button>
            </form>
        </section>

        <!-- Transactions -->
        <section class="transactions">
            <h3>Transaction History</h3>
            <table>
                <thead>
                    <tr>
                        <th>Type</th>
                        <th>Amount ($)</th>
                        <th>Description</th>
                        <th>Timestamp</th>
                        <th>To Account</th>
                    </tr>
                </thead>
                <tbody>
                    <% transactions.forEach(transaction => { %>
                        <tr>
                            <td><%= transaction.type %></td>
                            <td><%= transaction.amount %></td>
                            <td>
                                <%= transaction.description %>
                            </td>
                            <td>
                                <%= transaction.timestamp %>
                            </td>
                            <td>
                                <%= transaction.toAccount || 'N/A' %> </td>
                        </tr>
                        <% }) %>
                </tbody>
            </table>
        </section>
    </main>
</body>

</html>